---
// src/pages/magazine.astro
import "../styles/_editor.scss";
---

<html>
  <head>
    <meta name="robots" content="noindex, nofollow" />
    <title>Magazine</title>
  </head>

  <body>
    <div class="magazine-preview">
      <iframe
        id="magazine-frame"
        src="/preview"
        style="width: 100%; height: 540px; border: none;"></iframe>
    </div>

    <div id="editor-controls">
      <h1>Editor</h1>
      <div id="front-matter">
        <h2>Front Cover</h2>
        <div class="color-picker-container">
          <label for="magazine-background-color-picker">Background Color:</label
          >
          <div id="magazine-background-color-picker" class="color-picker"></div>
        </div>
        <div class="color-picker-container">
          <label for="argama-color-picker">Title Color:</label>
          <div id="argama-color-picker" class="color-picker"></div>
        </div>
        <div class="cover-image-picker">
          <label for="cover-image">Cover Image:</label>
          <input type="file" id="cover-image" accept="image/*" />
        </div>
        <div class="input-group">
          <label for="artist-input">Illustration Credit:</label>
          <input type="text" id="artist-input" value="[ARTIST]" />
        </div>
        <div class="input-group">
          <label for="character-name-input">Character Name:</label>
          <input type="text" id="character-name-input" value="射命丸文" />
        </div>
<div class="input-group">
          <label for="issue-number-input">Issue Number:</label>
          <input 
            type="number" 
            id="issue-number-input" 
            value="1" 
            min="1" 
            step="1" 
          />
        </div>
      </div>
      
    </div>
    <script>
      import "../scripts/editor-logic.ts";
    </script>
  </body>
</html>
